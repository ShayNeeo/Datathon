\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Customer Quality Shift:} Post-2018 cohorts (the Double Day discount regime) show structurally weaker repeat value and lower baseline loyalty than the original community-driven cohorts.}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{fig:appendix_customer_quality}{{8}{6}{\textbf {Customer Quality Shift:} Post-2018 cohorts (the Double Day discount regime) show structurally weaker repeat value and lower baseline loyalty than the original community-driven cohorts}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Acquisition Efficiency:} Channel performance diverges materially, so CAC targets should be calibrated by channel quality rather than blended across all new customers.}}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig:appendix_acquisition_efficiency}{{9}{7}{\textbf {Acquisition Efficiency:} Channel performance diverges materially, so CAC targets should be calibrated by channel quality rather than blended across all new customers}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Single-Order Problem:} The order-frequency distribution confirms that the loyalty collapse is not abstract — it is visible as a large single-purchase customer base.}}{7}{figure.caption.13}\protected@file@percent }
\newlabel{fig:appendix_order_freq}{{10}{7}{\textbf {Single-Order Problem:} The order-frequency distribution confirms that the loyalty collapse is not abstract — it is visible as a large single-purchase customer base}{figure.caption.13}{}}
