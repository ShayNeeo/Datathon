\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces \textbf  {Campaign ROI:} Spring Sale creates profitable lift, while Year-End Sale destroys both revenue and margin, proving that campaign mechanics matter more than discount volume.}}{10}{figure.caption.18}\protected@file@percent }
\newlabel{fig:appendix_campaign}{{15}{10}{\textbf {Campaign ROI:} Spring Sale creates profitable lift, while Year-End Sale destroys both revenue and margin, proving that campaign mechanics matter more than discount volume}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {Promo Urgency \& Stackability:} Final-window urgency can lift conversion, but stackable discounts risk margin dilution beyond the safe threshold.}}{10}{figure.caption.19}\protected@file@percent }
\newlabel{fig:appendix_stackability}{{16}{10}{\textbf {Promo Urgency \& Stackability:} Final-window urgency can lift conversion, but stackable discounts risk margin dilution beyond the safe threshold}{figure.caption.19}{}}
