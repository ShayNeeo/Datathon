\@writefile{toc}{\contentsline {subsection}{\numberline {A.1}A. Product \& Market Dominance (Direction 01)}{5}{subsection.A.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Sizing margin pockets:} The L/XL size bands hold the highest absolute unit profitability in the streetwear assortment, indicating that the business should over-index supply chain planning toward larger sizes.}}{5}{figure.caption.8}\protected@file@percent }
\newlabel{fig:appendix_margin_size}{{5}{5}{\textbf {Sizing margin pockets:} The L/XL size bands hold the highest absolute unit profitability in the streetwear assortment, indicating that the business should over-index supply chain planning toward larger sizes}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Loss Leader Trap:} Low-margin SKUs generate revenue but destroy basket profit, proving that traffic products need bundling or margin-floor guardrails.}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:loss_leader_trap}{{6}{5}{\textbf {Loss Leader Trap:} Low-margin SKUs generate revenue but destroy basket profit, proving that traffic products need bundling or margin-floor guardrails}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {R\&D Evolution:} Newest product iterations (suffix > 70) generate 64\% more average revenue per SKU than original classic models, proving that active product innovation outpaces passive restocking.}}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig:appendix_rd}{{7}{6}{\textbf {R\&D Evolution:} Newest product iterations (suffix > 70) generate 64\% more average revenue per SKU than original classic models, proving that active product innovation outpaces passive restocking}{figure.caption.10}{}}
